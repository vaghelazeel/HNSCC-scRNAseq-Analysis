    {
      "cell_type": "code",
      "source": [
        "cancer_expr = expr[cancer_cells.tolist()]\n",
        "noncancer_expr = expr[noncancer_cells.tolist()]\n",
        "\n",
        "results = []\n",
        "for gene in expr_top.index:\n",
        "    cancer_vals = cancer_expr.loc[gene].values\n",
        "    noncancer_vals = noncancer_expr.loc[gene].values\n",
        "    stat, pval = stats.mannwhitneyu(cancer_vals, noncancer_vals, alternative='two-sided')\n",
        "    mean_cancer = cancer_vals.mean()\n",
        "    mean_noncancer = noncancer_vals.mean()\n",
        "    log2fc = np.log2((mean_cancer + 0.1) / (mean_noncancer + 0.1))\n",
        "    results.append({'gene': gene, 'log2fc': log2fc, 'pval': pval})\n",
        "\n",
        "results_df = pd.DataFrame(results)\n",
        "results_df['neg_log10_pval'] = -np.log10(results_df['pval'] + 1e-300)\n",
        "\n",
        "print(\"Top 10 upregulated genes in cancer cells:\")\n",
        "print(results_df.sort_values('log2fc', ascending=False).head(10)[['gene', 'log2fc', 'pval']])"
      ],
