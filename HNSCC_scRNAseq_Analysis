        "\n",
        "import gzip\n",
        "\n",
        "# Read the compressed file directly\n",
        "with gzip.open('GSE103322_HNSCC_all_data.txt.gz', 'rt') as f:\n",
        "    df = pd.read_csv(f, sep='\\t', index_col=0)\n",
        "\n",
        "print(\"Dataset loaded.\")\n",
        "print(\"Shape:\", df.shape)\n",
        "print(\"First 5 gene names:\", df.index[:5].tolist())\n",
        "print(\"First 3 sample names:\", df.columns[:3].tolist())"
      ],
