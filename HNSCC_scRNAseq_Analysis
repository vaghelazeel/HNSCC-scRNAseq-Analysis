    {
      "cell_type": "code",
      "source": [
        "metadata = df.iloc[:5, :]\n",
        "expr = df.iloc[5:, :]\n",
        "\n",
        "expr = expr.apply(pd.to_numeric, errors='coerce')\n",
        "expr = expr.dropna(how='all')\n",
        "\n",
        "cell_labels = metadata.loc['classified  as cancer cell', :]\n",
        "\n",
        "print(\"Expression matrix shape:\", expr.shape)\n",
        "print(\"Cancer cells:\", (cell_labels == 1.0).sum())\n",
        "print(\"Non-cancer cells:\", (cell_labels == 0.0).sum())"
      ],
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "Eylo-j0XtAN8",
        "outputId": "a808e1b9-465b-49bf-a044-c6a0ea28e67a"
      },
      "execution_count": 9,
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "Expression matrix shape: (23686, 5902)\n",
            "Cancer cells: 2215\n",
            "Non-cancer cells: 324\n"
          ]
        }
      ]
    },
    {
      "cell_type": "code",
      "source": [
        "cancer_cells = cell_labels[cell_labels == 1.0].index\n",
        "noncancer_cells = cell_labels[cell_labels == 0.0].index\n",
        "\n",
        "expr_subset = expr[cancer_cells.tolist() + noncancer_cells.tolist()]\n",
        "labels_subset = ['Cancer'] * len(cancer_cells) + ['Non-cancer'] * len(noncancer_cells)\n",
        "\n",
        "gene_variance = expr_subset.var(axis=1)\n",
        "top_genes = gene_variance.nlargest(2000).index\n",
        "expr_top = expr_subset.loc[top_genes]\n",
        "\n",
        "scaler = StandardScaler()\n",
        "scaled = scaler.fit_transform(expr_top.T)\n",
        "\n",
        "pca = PCA(n_components=2)\n",
        "pca_result = pca.fit_transform(scaled)\n",
        "\n",
        "colors = ['#d62728' if l == 'Cancer' else '#1f77b4' for l in labels_subset]\n",
        "\n",
        "plt.figure(figsize=(10, 7))\n",
        "plt.scatter(pca_result[:, 0], pca_result[:, 1], c=colors, alpha=0.5, s=10)\n",
        "plt.xlabel('PC1 (' + str(round(pca.explained_variance_ratio_[0]*100, 1)) + '% variance)')\n",
        "plt.ylabel('PC2 (' + str(round(pca.explained_variance_ratio_[1]*100, 1)) + '% variance)')\n",
        "plt.title('PCA of HNSCC Cancer vs Non-Cancer Cells')\n",
        "\n",
        "from matplotlib.lines import Line2D\n",
        "legend_elements = [Line2D([0], [0], marker='o', color='w', markerfacecolor='#d62728', markersize=8, label='Cancer'),\n",
        "                   Line2D([0], [0], marker='o', color='w', markerfacecolor='#1f77b4', markersize=8, label='Non-cancer')]\n",
        "plt.legend(handles=legend_elements, loc='upper right')\n",
        "plt.tight_layout()\n",
        "plt.savefig('PCA_cancer_vs_noncancer.png', dpi=150)\n",
        "plt.show()\n",
        "print(\"PCA plot saved.\")"
      ],
